{
  // ── Haven — Branded Editor Settings ──────────────────
  // These settings apply the brand's typography and motion tokens
  // to the VS Code properties that themes cannot control.

  // Typography — Source Code Pro (--font-mono)
  "editor.fontFamily": "'Source Code Pro', monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.55,
  "editor.fontLigatures": false,

  // Terminal — same font, slightly smaller
  "terminal.integrated.fontFamily": "'Source Code Pro', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.45,

  // Motion — smooth cursor (--ease-transition, --duration-fast)
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,

  // Bracket pairs — brand teal/sage palette
  "editor.bracketPairColorization.enabled": true,
  "workbench.colorCustomizations": {
    "[Haven Light]": {
      "editorBracketHighlight.foreground1": "#1B685E",
      "editorBracketHighlight.foreground2": "#3A643D",
      "editorBracketHighlight.foreground3": "#0B4E6C",
      "editorBracketHighlight.foreground4": "#754B00",
      "editorBracketHighlight.foreground5": "#124D45",
      "editorBracketHighlight.foreground6": "#5B544C"
    },
    "[Haven Dark]": {
      "editorBracketHighlight.foreground1": "#7CB9AD",
      "editorBracketHighlight.foreground2": "#81B983",
      "editorBracketHighlight.foreground3": "#6FA5C4",
      "editorBracketHighlight.foreground4": "#CEA861",
      "editorBracketHighlight.foreground5": "#A8D1C9",
      "editorBracketHighlight.foreground6": "#B3ADA4"
    },
    "[Haven Warm Light]": {
      "editorBracketHighlight.foreground1": "#1B685E",
      "editorBracketHighlight.foreground2": "#3A643D",
      "editorBracketHighlight.foreground3": "#0B4E6C",
      "editorBracketHighlight.foreground4": "#754B00",
      "editorBracketHighlight.foreground5": "#124D45",
      "editorBracketHighlight.foreground6": "#5B544C"
    },
    "[Haven Warm Dark]": {
      "editorBracketHighlight.foreground1": "#7CB9AD",
      "editorBracketHighlight.foreground2": "#81B983",
      "editorBracketHighlight.foreground3": "#6FA5C4",
      "editorBracketHighlight.foreground4": "#CEA861",
      "editorBracketHighlight.foreground5": "#A8D1C9",
      "editorBracketHighlight.foreground6": "#B3ADA4"
    }
  },

  // Minimap — off (reduces visual noise, aligns with restraint principle)
  "editor.minimap.enabled": false,

  // Whitespace — boundary only (clean editor, show trailing)
  "editor.renderWhitespace": "boundary",

  // Line length — 75 chars max (brand spec from typography tokens)
  "editor.rulers": [75],
  "editor.wordWrapColumn": 75
}
