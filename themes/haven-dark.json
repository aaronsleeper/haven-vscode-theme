{
  "$schema": "vscode://schemas/color-theme",
  "name": "Haven Teal Dark",
  "type": "dark",
  "colors": {

    // ── Surface Depth Map ──────────────────────────────────
    //
    //   Layer 0  #010F0C  teal-50    Editor canvas (deepest)
    //   Layer 1  #04201C  teal-75    Tab bar (flat), title bar (flat)
    //   Layer 2  #04201C  teal-100   Activity bar, sidebar
    //   Layer 3  #04201C  teal-110   Panel / terminal
    //   Layer 4  #0D322D  teal-150   Section headers, strong borders
    //   Layer 5  #0D322D  teal-200   Status bar (flat)
    //
    //   Borders (#0D322D30) crisply separate surfaces.
    //   Gradients only on tall surfaces (sidebar, activity bar, panel).
    //   Bars (status, title, tabs) stay flat — no vertical gradient.

    // ── Editor ──────────────────────────────────────────────
    // Layer 0 — deepest surface. Maximum text contrast (~19.5:1)
    "editor.background": "#010F0C",
    "editor.foreground": "#FBFAF8",
    "editor.lineHighlightBackground": "#124D4518",
    "editor.lineHighlightBorder": "#124D4500",
    "editor.selectionBackground": "#81B98360",
    "editor.selectionHighlightBackground": "#81B98320",
    "selection.background": "#81B98360",
    "editor.wordHighlightBackground": "#52A39530",
    "editor.wordHighlightStrongBackground": "#52A39545",
    "editor.findMatchBackground": "#CEA86150",
    "editor.findMatchHighlightBackground": "#CEA86125",
    "editor.rangeHighlightBackground": "#0D322D25",
    "editor.hoverHighlightBackground": "#52A39518",
    "editor.foldBackground": "#0D322D20",
    "editorCursor.foreground": "#52A395",
    "editorWhitespace.foreground": "#0D322D50",
    "editorIndentGuide.background": "#0D322D40",
    "editorIndentGuide.activeBackground": "#1B685E60",
    "editorLineNumber.foreground": "#124D45",
    "editorLineNumber.activeForeground": "#52A395",
    "editorRuler.foreground": "#0D322D40",
    "editorBracketMatch.background": "#52A39530",
    "editorBracketMatch.border": "#52A39580",
    "editorOverviewRuler.border": "#0D322D00",
    "editorGutter.addedBackground": "#3A8E64",
    "editorGutter.modifiedBackground": "#CEA861",
    "editorGutter.deletedBackground": "#D87972",
    "editorError.foreground": "#D87972",
    "editorWarning.foreground": "#CEA861",
    "editorInfo.foreground": "#538EB0",

    // ── Sticky Scroll ─────────────────────────────────────
    "editorStickyScroll.background": "#010F0C",
    "editorStickyScrollHover.background": "#04201C",

    // ── Inlay Hints ───────────────────────────────────────
    "editorInlayHint.background": "#0D322D30",
    "editorInlayHint.foreground": "#3A847890",
    "editorInlayHint.typeForeground": "#52A39580",
    "editorInlayHint.parameterForeground": "#81B98370",

    // ── Ghost Text (AI completions) ───────────────────────
    "editorGhostText.foreground": "#3A847860",

    // ── Editor Groups & Tabs ────────────────────────────────
    // Layer 1 (#04201C) — flat. Border separates from editor.
    // editorGroup.border separates side-by-side editor panes (incl. chat).
    "editorGroup.border": "#0D322D60",
    "editorGroupHeader.tabsBackground": "#04201C",
    "editorGroupHeader.noTabsBackground": "#04201C",
    "tab.activeBackground": "#010F0C",
    "tab.activeForeground": "#FBFAF8",
    "tab.activeBorderTop": "#52A395",
    "tab.inactiveBackground": "#04201C",
    "tab.inactiveForeground": "#7CB9AD80",
    "tab.border": "#04201C00",
    "tab.hoverBackground": "#010F0C",
    "tab.hoverForeground": "#FBFAF8",
    "tab.unfocusedActiveBackground": "#010F0C",
    "tab.unfocusedActiveForeground": "#7CB9AD",
    "tab.unfocusedInactiveBackground": "#04201C",
    "tab.unfocusedInactiveForeground": "#3A8478",

    // ── Title Bar ───────────────────────────────────────────
    // Layer 1 (#04201C) — flat, matches tab bar. Border below.
    "titleBar.activeBackground": "#04201C",
    "titleBar.activeForeground": "#FBFAF8",
    "titleBar.inactiveBackground": "#04201C",
    "titleBar.inactiveForeground": "#3A8478",
    "titleBar.border": "#0D322D30",

    // ── Activity Bar ────────────────────────────────────────
    // Layer 2 (#04201C) — matches sidebar. CSS adds vertical gradient.
    // Right border separates from sidebar content.
    "activityBar.background": "#04201C",
    "activityBar.foreground": "#52A395",
    "activityBar.inactiveForeground": "#1B685E80",
    "activityBar.border": "#0D322D30",
    "activityBarBadge.background": "#52A395",
    "activityBarBadge.foreground": "#010F0C",

    // ── Sidebar ─────────────────────────────────────────────
    // Layer 2 (#04201C) — matches activity bar. CSS adds vertical gradient.
    // Right border separates from editor.
    "sideBar.background": "#04201C",
    "sideBar.foreground": "#FBFAF8",
    "sideBar.border": "#0D322D30",
    "sideBar.dropBackground": "#52A39520",
    "sideBarTitle.foreground": "#FBFAF8",
    "sideBarSectionHeader.background": "#0D322D",
    "sideBarSectionHeader.foreground": "#7CB9AD",
    "sideBarSectionHeader.border": "#0D322D00",

    // ── Status Bar ──────────────────────────────────────────
    // Layer 5 (#0D322D) — flat, brightest chrome. Border above.
    // #FBFAF8 on #0D322D = ~9.2:1. AAA ✓
    "statusBar.background": "#0D322D",
    "statusBar.foreground": "#FBFAF8",
    "statusBar.border": "#0D322D30",
    "statusBar.debuggingBackground": "#124D45",
    "statusBar.debuggingForeground": "#FBFAF8",
    "statusBar.noFolderBackground": "#04201C",
    "statusBar.noFolderForeground": "#3A8478",
    "statusBarItem.hoverBackground": "#124D4560",
    "statusBarItem.prominentBackground": "#124D45",
    "statusBarItem.prominentHoverBackground": "#1B685E",
    "statusBarItem.remoteBackground": "#1B685E",
    "statusBarItem.remoteForeground": "#FBFAF8",

    // ── Panel ───────────────────────────────────────────────
    // Layer 3 (#04201C) — distinct from sidebar. CSS adds vertical gradient.
    // Top border separates from editor.
    "panel.background": "#04201C",
    "panel.border": "#0D322D30",
    "panelTitle.activeBorder": "#52A395",
    "panelTitle.activeForeground": "#FBFAF8",
    "panelTitle.inactiveForeground": "#3A8478",
    "panelSectionHeader.background": "#0D322D",
    "panelSectionHeader.border": "#0D322D30",
    "panelSection.border": "#0D322D30",

    // ── Text Blocks (chat, hover, markdown preview) ───────
    // Code blocks sit on Layer 2 — subtle lift from chat (Layer 1) without harsh pop
    "textCodeBlock.background": "#04201C",
    "textBlockQuote.background": "#04201C",
    "textBlockQuote.border": "#1B685E",
    "textPreformat.foreground": "#A8D1C9",
    "textPreformat.background": "#04201C",
    "textLink.foreground": "#52A395",
    "textLink.activeForeground": "#7CB9AD",
    "textSeparator.foreground": "#0D322D30",

    // ── Chat ────────────────────────────────────────────────
    "chat.requestBackground": "#04201C",
    "chat.requestBorder": "#0D322D40",
    "chat.slashCommandBackground": "#1B685E30",
    "chat.slashCommandForeground": "#52A395",

    // ── Inputs ──────────────────────────────────────────────
    "input.background": "#010F0C",
    "input.foreground": "#FBFAF8",
    "input.border": "#0D322D",
    "input.placeholderForeground": "#3A847860",
    "inputOption.activeBorder": "#52A395",
    "inputOption.activeBackground": "#52A39520",
    "inputOption.activeForeground": "#FBFAF8",
    "inputValidation.errorBackground": "#932B2A30",
    "inputValidation.errorBorder": "#D87972",
    "inputValidation.warningBackground": "#754B0030",
    "inputValidation.warningBorder": "#CEA861",
    "inputValidation.infoBackground": "#0B4E6C30",
    "inputValidation.infoBorder": "#538EB0",

    // ── Buttons ─────────────────────────────────────────────
    "button.background": "#1B685E",
    "button.foreground": "#FBFAF8",
    "button.hoverBackground": "#3A8478",
    "button.secondaryBackground": "#0D322D",
    "button.secondaryForeground": "#FBFAF8",
    "button.secondaryHoverBackground": "#0D322D",

    // ── Dropdown ────────────────────────────────────────────
    "dropdown.background": "#010F0C",
    "dropdown.foreground": "#FBFAF8",
    "dropdown.border": "#0D322D",
    "dropdown.listBackground": "#04201C",

    // ── Badges ──────────────────────────────────────────────
    "badge.background": "#52A395",
    "badge.foreground": "#010F0C",

    // ── Scrollbar ───────────────────────────────────────────
    // Slider must be distinct from adjacent panels (chat, sidebar).
    // Using warm neutral tint to separate from teal chrome surfaces.
    "scrollbar.shadow": "#010F0C80",
    "scrollbarSlider.background": "#3A847840",
    "scrollbarSlider.hoverBackground": "#52A39560",
    "scrollbarSlider.activeBackground": "#52A39580",

    // ── Lists & Trees ───────────────────────────────────────
    "list.activeSelectionBackground": "#1B685E35",
    "list.activeSelectionForeground": "#FBFAF8",
    "list.activeSelectionIconForeground": "#FBFAF8",
    "list.inactiveSelectionBackground": "#0D322D40",
    "list.inactiveSelectionForeground": "#FBFAF8",
    "list.hoverBackground": "#0D322D30",
    "list.hoverForeground": "#FBFAF8",
    "list.focusBackground": "#1B685E30",
    "list.focusForeground": "#FBFAF8",
    "list.focusOutline": "#52A39560",
    "list.highlightForeground": "#52A395",
    "list.errorForeground": "#D87972",
    "list.warningForeground": "#CEA861",

    // ── Widgets ─────────────────────────────────────────────
    "widget.shadow": "#010F0C90",
    "widget.border": "#0D322D30",
    "editorWidget.background": "#04201C",
    "editorWidget.foreground": "#FBFAF8",
    "editorWidget.border": "#0D322D40",
    "editorSuggestWidget.background": "#04201C",
    "editorSuggestWidget.foreground": "#FBFAF8",
    "editorSuggestWidget.selectedBackground": "#1B685E30",
    "editorSuggestWidget.highlightForeground": "#52A395",
    "editorSuggestWidget.focusHighlightForeground": "#52A395",

    // ── Quick Input ───────────────────────────────────────
    "quickInput.background": "#04201C",
    "quickInput.foreground": "#FBFAF8",
    "quickInputList.focusBackground": "#1B685E30",
    "quickInputList.focusForeground": "#FBFAF8",
    "quickInputList.focusIconForeground": "#52A395",
    "quickInputTitle.background": "#04201C",

    // ── Peek View ───────────────────────────────────────────
    "peekView.border": "#52A39560",
    "peekViewEditor.background": "#010F0C",
    "peekViewEditor.matchHighlightBackground": "#CEA86140",
    "peekViewResult.background": "#04201C",
    "peekViewResult.fileForeground": "#FBFAF8",
    "peekViewResult.lineForeground": "#7CB9AD",
    "peekViewResult.matchHighlightBackground": "#CEA86130",
    "peekViewResult.selectionBackground": "#1B685E30",
    "peekViewResult.selectionForeground": "#FBFAF8",
    "peekViewTitle.background": "#010F0C",
    "peekViewTitleLabel.foreground": "#FBFAF8",
    "peekViewTitleDescription.foreground": "#7CB9AD",

    // ── Minimap ─────────────────────────────────────────────
    "minimap.background": "#010F0C",
    "minimap.findMatchHighlight": "#CEA86170",
    "minimap.selectionHighlight": "#52A39550",
    "minimap.errorHighlight": "#D87972",
    "minimap.warningHighlight": "#CEA861",
    "minimapGutter.addedBackground": "#3A8E64",
    "minimapGutter.modifiedBackground": "#CEA861",
    "minimapGutter.deletedBackground": "#D87972",
    "minimapSlider.background": "#1B685E20",
    "minimapSlider.hoverBackground": "#1B685E35",
    "minimapSlider.activeBackground": "#1B685E50",

    // ── Breadcrumbs ─────────────────────────────────────────
    "breadcrumb.foreground": "#3A8478",
    "breadcrumb.focusForeground": "#7CB9AD",
    "breadcrumb.activeSelectionForeground": "#FBFAF8",
    "breadcrumbPicker.background": "#04201C",

    // ── Git Decorations ─────────────────────────────────────
    "gitDecoration.addedResourceForeground": "#81B983",
    "gitDecoration.modifiedResourceForeground": "#CEA861",
    "gitDecoration.deletedResourceForeground": "#D87972",
    "gitDecoration.untrackedResourceForeground": "#538EB0",
    "gitDecoration.conflictingResourceForeground": "#D87972",
    "gitDecoration.ignoredResourceForeground": "#3A8478",
    "gitDecoration.stageModifiedResourceForeground": "#52A395",
    "gitDecoration.stageDeletedResourceForeground": "#D87972",

    // ── Diff Editor ─────────────────────────────────────────
    "diffEditor.insertedTextBackground": "#81B98318",
    "diffEditor.removedTextBackground": "#D8797218",
    "diffEditor.insertedLineBackground": "#81B98310",
    "diffEditor.removedLineBackground": "#D8797210",
    "diffEditor.diagonalFill": "#0D322D30",

    // ── Merge Conflicts ─────────────────────────────────────
    "merge.currentHeaderBackground": "#3A8E6440",
    "merge.currentContentBackground": "#3A8E6418",
    "merge.incomingHeaderBackground": "#538EB040",
    "merge.incomingContentBackground": "#538EB018",

    // ── Focus Border ────────────────────────────────────────
    "focusBorder": "#52A39580",

    // ── Terminal ────────────────────────────────────────────
    // Layer 4 (#051E1A) — matches panel altitude
    "terminal.background": "#04201C",
    "terminal.foreground": "#FBFAF8",
    "terminal.ansiBlack": "#010F0C",
    "terminal.ansiRed": "#D87972",
    "terminal.ansiGreen": "#81B983",
    "terminal.ansiYellow": "#CEA861",
    "terminal.ansiBlue": "#538EB0",
    "terminal.ansiMagenta": "#D87972",
    "terminal.ansiCyan": "#52A395",
    "terminal.ansiWhite": "#FBFAF8",
    "terminal.ansiBrightBlack": "#3A8478",
    "terminal.ansiBrightRed": "#E09990",
    "terminal.ansiBrightGreen": "#ACCFAD",
    "terminal.ansiBrightYellow": "#CEA861",
    "terminal.ansiBrightBlue": "#7CB1CC",
    "terminal.ansiBrightMagenta": "#E09990",
    "terminal.ansiBrightCyan": "#7CB9AD",
    "terminal.ansiBrightWhite": "#FBFAF8",
    "terminal.selectionBackground": "#52A39540",
    "terminalCursor.foreground": "#52A395",

    // ── Notification ────────────────────────────────────────
    "notificationCenter.border": "#0D322D30",
    "notifications.background": "#04201C",
    "notifications.foreground": "#FBFAF8",
    "notifications.border": "#0D322D30",
    "notificationsErrorIcon.foreground": "#D87972",
    "notificationsWarningIcon.foreground": "#CEA861",
    "notificationsInfoIcon.foreground": "#538EB0",

    // ── Command Center ──────────────────────────────────────
    "commandCenter.background": "#010F0C80",
    "commandCenter.foreground": "#7CB9AD",
    "commandCenter.border": "#0D322D40",
    "commandCenter.activeBackground": "#1B685E30",
    "commandCenter.activeForeground": "#FBFAF8",
    "commandCenter.activeBorder": "#52A39560",

    // ── Banner ──────────────────────────────────────────────
    "banner.background": "#0D322D",
    "banner.foreground": "#FBFAF8",
    "banner.iconForeground": "#52A395",

    // ── Welcome Page ────────────────────────────────────────
    "welcomePage.tileBackground": "#04201C",
    "welcomePage.tileBorder": "#0D322D40",
    "welcomePage.progress.foreground": "#52A395",
    "walkThrough.embeddedEditorBackground": "#010F0C",

    // ── Settings Editor ─────────────────────────────────────
    "settings.headerForeground": "#FBFAF8",
    "settings.modifiedItemIndicator": "#52A395",
    "settings.focusedRowBackground": "#1B685E15",
    "settings.rowHoverBackground": "#1B685E10",

    // ── Debug ───────────────────────────────────────────────
    "debugToolBar.background": "#04201C",
    "debugToolBar.border": "#0D322D40",
    "debugIcon.breakpointForeground": "#D87972",
    "debugIcon.startForeground": "#81B983",
    "debugIcon.pauseForeground": "#CEA861",
    "debugIcon.stopForeground": "#D87972",
    "debugIcon.disconnectForeground": "#D87972",
    "debugIcon.restartForeground": "#81B983",
    "debugIcon.stepOverForeground": "#52A395",
    "debugIcon.stepIntoForeground": "#52A395",
    "debugIcon.stepOutForeground": "#52A395",
    "debugIcon.continueForeground": "#81B983",
    "debugConsole.infoForeground": "#7CB9AD",
    "debugConsole.warningForeground": "#CEA861",
    "debugConsole.errorForeground": "#D87972",
    "debugConsoleInputIcon.foreground": "#52A395"
  },

  "semanticHighlighting": true,

  "semanticTokenColors": {
    // ── Semantic: Types ────────────────────────────────────
    "type": "#A8D1C9",
    "type.declaration": { "foreground": "#A8D1C9", "fontStyle": "bold" },
    "interface": { "foreground": "#A8D1C9", "fontStyle": "italic" },
    "interface.declaration": { "foreground": "#A8D1C9", "fontStyle": "bold italic" },
    "enum": "#6FA5C4",
    "enum.declaration": { "foreground": "#6FA5C4", "fontStyle": "bold" },
    "enumMember": "#6FA5C4",
    "typeParameter": { "foreground": "#689B6A", "fontStyle": "italic" },
    "namespace": "#52A395",

    // ── Semantic: Functions ────────────────────────────────
    "function": "#81B983",
    "function.declaration": { "foreground": "#81B983", "fontStyle": "bold" },
    "method": "#81B983",
    "method.declaration": { "foreground": "#81B983", "fontStyle": "bold" },

    // ── Semantic: Variables ────────────────────────────────
    "variable": "#FBFAF8",
    "variable.readonly": "#D1CDC6",
    "variable.defaultLibrary": "#A8D1C9",
    "parameter": "#FBFAF8",
    "parameter.declaration": { "foreground": "#FBFAF8", "fontStyle": "italic" },
    "property": "#D1CDC6",
    "property.readonly": "#B3ADA4",
    "property.declaration": "#D1CDC6",

    // ── Semantic: Decorators ──────────────────────────────
    "decorator": { "foreground": "#ACCFAD", "fontStyle": "italic" }
  },

  "tokenColors": [

    // ── Comments ────────────────────────────────────────────
    // Warm neutral (#958E85) · ~8.7:1 on #010F0C · AAA ✓
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#958E85",
        "fontStyle": "italic"
      }
    },

    // ── Doc Comments ────────────────────────────────────────
    // Slightly brighter than regular comments for emphasis
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#B3ADA4",
        "fontStyle": "italic"
      }
    },

    // ── Keywords ────────────────────────────────────────────
    // teal-700 (#7CB9AD) · ~11.0:1 on #010F0C · AAA ✓
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7CB9AD"
      }
    },

    // ── Control Flow ────────────────────────────────────────
    // Slightly emphasized — teal-800 with italic for flow keywords
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#A8D1C9",
        "fontStyle": "italic"
      }
    },

    // ── Import / Export ─────────────────────────────────────
    // Muted teal — structural but recessive
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#3A847890"
      }
    },

    // ── Strings ─────────────────────────────────────────────
    // Warm amber (#CEA861) · ~11.0:1 on #010F0C · AAA ✓
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#CEA861"
      }
    },

    // ── Numbers, Booleans, Constants ────────────────────────
    // Lightened info-blue (#6FA5C4) · ~9.3:1 on #010F0C · AAA ✓
    {
      "name": "Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#6FA5C4"
      }
    },

    // ── Types, Classes, Interfaces ──────────────────────────
    // teal-800 (#A8D1C9) · ~14.0:1 on #010F0C · AAA ✓
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias"
      ],
      "settings": {
        "foreground": "#A8D1C9"
      }
    },

    // ── Functions and Methods ────────────────────────────────
    // sage-700 / brand-sage (#81B983) · ~10.4:1 on #010F0C · AAA ✓
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#81B983"
      }
    },

    // ── Variables ────────────────────────────────────────────
    // warm off-white (#FBFAF8) · ~19.5:1 on #010F0C · AAA ✓
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FBFAF8"
      }
    },

    // ── Properties ──────────────────────────────────────────
    // warm-700 (#D1CDC6) · ~15.3:1 on #010F0C · AAA ✓
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#D1CDC6"
      }
    },

    // ── Operators and Punctuation ────────────────────────────
    // warm-600 (#B3ADA4) · ~11.1:1 on #010F0C · AAA ✓
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.ternary",
        "punctuation"
      ],
      "settings": {
        "foreground": "#B3ADA4"
      }
    },

    // ── HTML/XML Tags ───────────────────────────────────────
    // teal-700 (#7CB9AD) · ~11.0:1 on #010F0C · AAA ✓
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7CB9AD"
      }
    },

    // ── HTML/XML Attributes ─────────────────────────────────
    // sage-700 (#81B983) · ~10.4:1 on #010F0C · AAA ✓
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#81B983"
      }
    },

    // ── Regex and Escape Characters ─────────────────────────
    // Lightened error-border (#E09990) · ~10.3:1 on #010F0C · AAA ✓
    {
      "name": "Regex and Escapes",
      "scope": [
        "string.regexp",
        "constant.character.escape",
